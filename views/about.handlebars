<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>About - LabReserve</title>
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body class="bg">
  <header>
    <nav class="navbar">
      <a class="logo" href="/home">LabReserve.</a>
      <ul class="nav-links">
        <li><a href="/home">Home</a></li>
        <li><a href="/about">About</a></li>
        <li><a href="#" id="logoutBtn">Logout</a></li>
      </ul>
    </nav>
  </header>

  <main class="container">
    <h2>🛠️ NPM Packages & Technologies</h2>
    
    <div class="form-card">
      <h3>Backend</h3>
      <ul style="text-align: left;">
        <li><strong>express</strong> - Web framework</li>
        <li><strong>mongoose</strong> - MongoDB ORM</li>
        <li><strong>express-handlebars</strong> - Templating engine</li>
        <li><strong>express-session</strong> - User sessions</li>
        <li><strong>bcryptjs</strong> - Password hashing</li>
        <li><strong>dotenv</strong> - Environment variables</li>
      </ul>

      <h3>Frontend</h3>
      <ul style="text-align: left;">
        <li><strong>Handlebars</strong> - MVC Views</li>
        <li><strong>CSS3</strong> - Responsive design</li>
        <li><strong>Vanilla JS</strong> - Client-side logic</li>
      </ul>

      <h3>Database</h3>
      <ul style="text-align: left;">
        <li><strong>MongoDB</strong> - NoSQL database</li>
      </ul>

      <h3>Features Implemented</h3>
      <ul style="text-align: left;">
        <li>✅ MVC Architecture</li>
        <li>✅ Full CRUD Operations</li>
        <li>✅ User Authentication + Sessions</li>
        <li>✅ Password Hashing</li>
        <li>✅ Form Validation</li>
        <li>✅ 5+ Sample Data (Labs/Users)</li>
        <li>✅ Responsive Design</li>
        <li>✅ Deployed (Render/MongoDB Atlas)</li>
      </ul>
    </div>

    <div style="text-align: center; margin-top: 30px;">
      <a href="/home" class="btn-large">Back to Home</a>
    </div>
  </main>

  {{> logout}}
  <script src="/js/script.js"></script>
</body>
</html>